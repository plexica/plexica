{
  "name": "@plexica/plugin-crm",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"tsx watch src/index.ts\" \"vite dev --port 4001\"",
    "dev:backend": "tsx watch src/index.ts",
    "dev:ui": "vite dev --port 4001",
    "build": "pnpm build:backend && pnpm build:ui",
    "build:backend": "tsc",
    "build:ui": "NODE_ENV=production vite build",
    "preview:ui": "vite preview --port 4001 --strictPort",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.ui.json",
    "start": "node dist/index.js",
    "migration:apply": "echo 'Apply migrations via core API'"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@fastify/cors": "^11.0.0",
    "@plexica/ui": "workspace:*",
    "@tanstack/react-query": "latest",
    "fastify": "^5.0.0",
    "pg": "^8.13.0",
    "pino": "^9.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.82.0",
    "react-intl": "^6.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@plexica/vite-plugin": "workspace:*",
    "@originjs/vite-plugin-federation": "^1.4.1",
    "@vitejs/plugin-react": "^4.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.2.4",
    "tsx": "^4.0.0",
    "typescript": "^5.9.0",
    "vite": "^6.0.0"
  }
}
