{
  "name": "@plexica/plugin-crm",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"tsx watch src/index.ts\" \"vite dev --port 4001\"",
    "dev:backend": "tsx watch src/index.ts",
    "dev:ui": "vite dev --port 4001",
    "build": "tsc && vite build",
    "start": "node dist/index.js",
    "migration:apply": "echo 'Apply migrations via core API'"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@plexica/vite-plugin": "workspace:*",
    "@vitejs/plugin-react": "^4.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.39",
    "concurrently": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.0",
    "vite": "^6.0.0"
  }
}
