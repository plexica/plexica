{
  "name": "plexica",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Plexica v2 — Multi-tenant SaaS platform",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:lines": "bash scripts/check-authored-lines.sh",
    "test:line-gate": "bash scripts/check-authored-lines.test.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.65.0",
    "eslint": "^9.39.5",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-storybook": "10.4.6",
    "prettier": "^3.9.6",
    "typescript": "^5.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ],
    "overrides": {
      "lodash": "^4.18.1",
      "js-yaml": "4.2.0",
      "fast-uri": "3.1.4",
      "fast-xml-builder": "1.1.7",
      "fast-xml-parser": "5.7.0",
      "@babel/core": "7.29.6",
      "protobufjs": "7.6.5",
      "ws": "8.21.0"
    },
    "peerDependencyRules": {
      "ignoreMissing": [],
      "allowedVersions": {
        "react-intl>react": "19"
      }
    }
  }
}
