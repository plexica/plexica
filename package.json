{
  "name": "plexica",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Plexica v2 — Multi-tenant SaaS platform",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-storybook": "10.3.3",
    "prettier": "^3.0.0",
    "typescript": "^5.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ],
    "overrides": {
      "lodash": "^4.18.1"
    },
    "peerDependencyRules": {
      "ignoreMissing": [],
      "allowedVersions": {
        "react-intl>react": "19"
      }
    }
  }
}
