# ─────────────────────────────────────────────────────────────────────────────
# Plexica v2 — Environment Variables
# Copy this file to .env and adjust values for your local environment.
# NEVER commit .env — it contains real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PORT=5432
POSTGRES_DB=plexica
POSTGRES_USER=plexica
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://plexica:changeme@localhost:5432/plexica

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_PORT=8080
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme

# ── Redpanda (Kafka-compatible) ───────────────────────────────────────────────
REDPANDA_KAFKA_PORT=19092
REDPANDA_ADMIN_PORT=9644
KAFKA_BROKERS=localhost:19092

# ── Mailhog (SMTP dev server) ─────────────────────────────────────────────────
SMTP_PORT=1025
SMTP_UI_PORT=8025
SMTP_HOST=localhost

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── GitHub (MCP integration) ──────────────────────────────────────────────────
# GITHUB_TOKEN=ghp_...
