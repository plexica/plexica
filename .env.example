# ─────────────────────────────────────────────────────────────────────────────
# Plexica v2 — Environment Variables
# Copy this file to .env and adjust values for your local environment.
# NEVER commit .env — it contains real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PORT=5432
POSTGRES_DB=plexica
POSTGRES_USER=plexica
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://plexica:changeme@localhost:5432/plexica
# Development/test must explicitly disable TLS. Production requires verify-full.
PLUGIN_DB_SSL_MODE=disable
# Production-only absolute CA path mounted read-only into core and plugin runtimes.
# PLUGIN_DB_SSL_ROOT_CERT_PATH=/run/secrets/plexica/postgres-ca.crt
# Optional when a Docker plugin reaches PostgreSQL/Core through different hosts.
# PLUGIN_DB_HOST=postgres
# PLUGIN_DOCKER_NETWORK=plexica-production_default
# PLUGIN_CORE_API_URL=http://host.docker.internal:3001
# Required in production: 64 hexadecimal characters.
# PLUGIN_DB_ENCRYPTION_KEY=

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_PORT=8080
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=changeme
KEYCLOAK_ADMIN_ORIGIN=http://localhost:3002
KEYCLOAK_API_AUDIENCE=plexica-api

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme

# ── Redpanda (Kafka-compatible) ───────────────────────────────────────────────
REDPANDA_KAFKA_PORT=19092
REDPANDA_ADMIN_PORT=9644
KAFKA_BROKERS=localhost:19092
# Required in production. Generate unique 32-byte base64url key material.
# EVENT_KEY_ENCRYPTION_KEY=
# Required for plugin service credentials. Generate at least 32 random bytes.
# PLUGIN_CREDENTIAL_PEPPER=

# ── Mailpit (SMTP dev server) ─────────────────────────────────────────────────
SMTP_PORT=1025
SMTP_UI_PORT=8025
SMTP_HOST=localhost

# ── Loki + Grafana (log aggregation, ADR-022 Decision 3) ──────────────────────
LOKI_PORT=3100
LOKI_URL=http://localhost:3100
GRAFANA_PORT=3301
GRAFANA_URL=http://localhost:3301
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Higher limit for dev/E2E to avoid flaky rate-limit tests (default 30)
RATE_LIMIT_RESOLVE_MAX=100

# ── E2E Testing (Playwright) ──────────────────────────────────────────────────
PLAYWRIGHT_API_URL=http://localhost:3001
# Must match RATE_LIMIT_RESOLVE_MAX so the test sends the right request count
PLAYWRIGHT_RATE_LIMIT_RESOLVE_MAX=100

# ── GitHub (MCP integration) ──────────────────────────────────────────────────
# GITHUB_TOKEN=ghp_...
