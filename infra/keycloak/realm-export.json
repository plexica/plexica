{
  "realm": "plexica-test",
  "displayName": "Plexica Test Realm",
  "enabled": true,
  "loginTheme": "plexica",
  "emailTheme": "keycloak",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "ssoSessionMaxLifespan": 36000,
  "accessTokenLifespan": 300,
  "clients": [
    {
      "clientId": "plexica-web",
      "name": "Plexica Web App",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": false,
      "redirectUris": ["http://localhost:3000/callback"],
      "webOrigins": ["http://localhost:3000"],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3000/?tenant=test"
      },
      "protocolMappers": [
        {
          "name": "audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "plexica-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "roles": {
    "realm": [
      { "name": "super_admin", "description": "Super administrator with full platform access" },
      { "name": "tenant_admin", "description": "Tenant administrator" },
      { "name": "member", "description": "Regular tenant member" }
    ]
  },
  "users": [
    {
      "username": "super-admin@plexica.test",
      "email": "super-admin@plexica.test",
      "firstName": "Super",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "test1234", "temporary": false }],
      "realmRoles": ["super_admin"]
    },
    {
      "username": "admin@acme.test",
      "email": "admin@acme.test",
      "firstName": "Acme",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "test1234", "temporary": false }],
      "realmRoles": ["tenant_admin"]
    },
    {
      "username": "member@acme.test",
      "email": "member@acme.test",
      "firstName": "Acme",
      "lastName": "Member",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "test1234", "temporary": false }],
      "realmRoles": ["member"]
    }
  ]
}
