{
  "name": "core-api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "start": "node dist/index.js",
    "db:generate": "dotenv -e ../../.env -- prisma generate && dotenv -e ../../.env -- prisma generate --schema=prisma/tenant-schema",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "tenant:create": "dotenv -e ../../.env -- tsx src/cli/create-tenant.ts",
    "tenant:migrate": "dotenv -e ../../.env -- tsx src/cli/migrate-tenants.ts",
    "test:unit": "vitest run --project unit",
    "test:int": "bash scripts/check-test-env.sh && vitest run --project integration",
    "test": "vitest run --project unit && bash scripts/check-test-env.sh && vitest run --project integration"
  },
  "dependencies": {
    "@fastify/http-proxy": "^11.5.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^6.19.3",
    "dockerode": "^5.0.1",
    "fastify": "^5.8.5",
    "ioredis": "^5.3.0",
    "jose": "^6.0.0",
    "kafkajs": "^2.2.4",
    "minio": "^8.0.0",
    "node-sql-parser": "^5.4.0",
    "nodemailer": "^9.0.3",
    "pino": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/node": "^20.19.43",
    "@types/nodemailer": "^6.4.23",
    "dotenv-cli": "^11.0.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.19.3",
    "tsx": "^4.0.0",
    "typescript": "^5.9.0",
    "vite": "^6.4.3",
    "vitest": "^4.1.9"
  }
}
