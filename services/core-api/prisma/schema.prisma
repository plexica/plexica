generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["core"]
}

enum TenantStatus {
  active
  suspended
  pending_deletion
  deleted

  @@schema("core")
}

model Tenant {
  id                       String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                     String                          @unique @db.VarChar(63)
  name                     String                          @db.VarChar(255)
  status                   TenantStatus                    @default(active)
  createdAt                DateTime                        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime                        @updatedAt @map("updated_at") @db.Timestamptz
  minioBucket              String?                         @unique @map("minio_bucket") @db.VarChar(255)
  version                  Int                             @default(1)
  deletionContext          Json?                           @map("deletion_context") @db.JsonB
  config                   TenantConfig?
  deletionSteps            TenantDeletionStep[]
  eventOutbox              EventOutbox[]
  eventKeys                TenantEventKey[]
  deadLetters              DeadLetterQueue[]
  serviceCredentials       PluginServiceCredential[]
  lifecycleReconciliations TenantLifecycleReconciliation[]

  @@index([status])
  @@map("tenants")
  @@schema("core")
}

model TenantConfig {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @unique @map("tenant_id") @db.Uuid
  keycloakRealm String   @unique @map("keycloak_realm") @db.VarChar(255)
  settings      Json     @default("{}") @db.JsonB
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_configs")
  @@schema("core")
}

model Plugin {
  id                        String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                      String                    @unique @db.VarChar(63)
  name                      String                    @db.VarChar(255)
  description               String?                   @db.Text
  version                   String                    @db.VarChar(32)
  author                    String                    @db.VarChar(255)
  iconUrl                   String?                   @map("icon_url")
  categories                Json                      @default("[]")
  manifest                  Json                      @default("{}")
  status                    String                    @default("draft") @db.VarChar(16)
  reviewStatus              String                    @default("none") @map("review_status") @db.VarChar(16)
  reviewNotes               String?                   @map("review_notes") @db.Text
  reviewedAt                DateTime?                 @map("reviewed_at") @db.Timestamptz
  reviewedBy                String?                   @map("reviewed_by") @db.VarChar(255)
  registryUrl               String                    @map("registry_url") @db.VarChar(512)
  imageName                 String                    @map("image_name") @db.VarChar(255)
  imageTag                  String                    @map("image_tag") @db.VarChar(64)
  imageDigest               String?                   @map("image_digest") @db.VarChar(128)
  pullPolicy                String                    @default("IfNotPresent") @map("pull_policy") @db.VarChar(16)
  registryCredentialsSecret String?                   @map("registry_credentials_secret")
  createdByKeycloakId       String                    @map("created_by_keycloak_id") @db.VarChar(255)
  createdAt                 DateTime                  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime                  @updatedAt @map("updated_at") @db.Timestamptz
  versions                  PluginVersion[]
  deadLetters               DeadLetterQueue[]
  serviceCredentials        PluginServiceCredential[]

  @@index([status])
  @@map("plugins")
  @@schema("core")
}

model PluginVersion {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pluginId    String   @map("plugin_id") @db.Uuid
  version     String   @db.VarChar(32)
  manifest    Json     @default("{}")
  imageDigest String?  @map("image_digest") @db.VarChar(128)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  plugin      Plugin   @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  @@unique([pluginId, version])
  @@map("plugin_versions")
  @@schema("core")
}

model DeadLetterQueue {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  installId         String    @map("install_id") @db.Uuid
  eventId           String    @map("event_id") @db.Uuid
  eventType         String    @map("event_type") @db.VarChar(128)
  schemaVersion     Int       @map("schema_version") @db.SmallInt
  payload           Json      @default("{}") @db.JsonB
  pluginId          String?   @map("plugin_id") @db.Uuid
  errorMessage      String?   @map("error_message") @db.VarChar(512)
  retryCount        Int       @default(0) @map("retry_count")
  originalTopic     String    @map("original_topic") @db.VarChar(128)
  originalPartition Int       @map("original_partition")
  originalOffset    BigInt    @map("original_offset")
  dedupeKey         String    @unique @map("dedupe_key") @db.Char(64)
  status            String    @default("pending") @db.VarChar(16)
  failedAt          DateTime  @default(now()) @map("failed_at") @db.Timestamptz
  resolvedAt        DateTime? @map("resolved_at") @db.Timestamptz
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  plugin            Plugin?   @relation(fields: [pluginId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, status, failedAt], map: "dead_letter_queue_tenant_status_failed_idx")
  @@index([pluginId, status], map: "dead_letter_queue_plugin_status_idx")
  @@map("dead_letter_queue")
  @@schema("core")
}

model EventOutbox {
  eventId        String    @id @map("event_id") @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  topic          String    @db.VarChar(128)
  eventType      String    @map("event_type") @db.VarChar(128)
  schemaVersion  Int       @map("schema_version") @db.SmallInt
  payload        Json      @db.JsonB
  producerKind   String    @map("producer_kind") @db.VarChar(16)
  producerId     String    @map("producer_id") @db.VarChar(64)
  correlationId  String    @map("correlation_id") @db.Uuid
  causationId    String?   @map("causation_id") @db.Uuid
  occurredAt     DateTime  @map("occurred_at") @db.Timestamptz
  attempts       Int       @default(0)
  availableAt    DateTime  @default(now()) @map("available_at") @db.Timestamptz
  leaseToken     String?   @map("lease_token") @db.Uuid
  leaseExpiresAt DateTime? @map("lease_expires_at") @db.Timestamptz
  lastErrorCode  String?   @map("last_error_code") @db.VarChar(64)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([availableAt, createdAt], map: "event_outbox_claim_idx")
  @@index([tenantId])
  @@map("event_outbox")
  @@schema("core")
}

model TenantEventKey {
  tenantId    String    @map("tenant_id") @db.Uuid
  keyVersion  Int       @map("key_version")
  status      String    @db.VarChar(16)
  wrappedKey  Bytes?    @map("wrapped_key") @db.ByteA
  wrapIv      Bytes?    @map("wrap_iv") @db.ByteA
  wrapTag     Bytes?    @map("wrap_tag") @db.ByteA
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  destroyedAt DateTime? @map("destroyed_at") @db.Timestamptz
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([tenantId, keyVersion])
  @@map("tenant_event_keys")
  @@schema("core")
}

model PluginServiceCredential {
  id           String    @id @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  installId    String    @map("install_id") @db.Uuid
  pluginId     String    @map("plugin_id") @db.Uuid
  pluginSlug   String    @map("plugin_slug") @db.VarChar(63)
  scope        String    @db.VarChar(32)
  secretDigest Bytes     @map("secret_digest") @db.ByteA
  version      Int
  status       String    @db.VarChar(16)
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  activatedAt  DateTime? @map("activated_at") @db.Timestamptz
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: NoAction)
  plugin       Plugin    @relation(fields: [pluginId], references: [id], onDelete: NoAction)

  @@unique([installId, version])
  @@index([tenantId])
  @@index([installId, status])
  @@map("plugin_service_credentials")
  @@schema("core")
}

model TenantDeletionStep {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  step           String    @db.VarChar(32)
  status         String    @default("pending") @db.VarChar(16)
  attempts       Int       @default(0)
  lastError      String?   @map("last_error") @db.Text
  leaseToken     String?   @map("lease_token") @db.Uuid
  leaseExpiresAt DateTime? @map("lease_expires_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  tenant         Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, step])
  @@index([status, updatedAt])
  @@map("tenant_deletion_steps")
  @@schema("core")
}

model TenantLifecycleReconciliation {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String       @map("tenant_id") @db.Uuid
  targetVersion  Int          @map("target_version")
  desiredStatus  TenantStatus @map("desired_status")
  status         String       @default("pending") @db.VarChar(16)
  attempts       Int          @default(0)
  availableAt    DateTime     @default(now()) @map("available_at") @db.Timestamptz
  leaseToken     String?      @map("lease_token") @db.Uuid
  leaseExpiresAt DateTime?    @map("lease_expires_at") @db.Timestamptz
  lastErrorCode  String?      @map("last_error_code") @db.VarChar(64)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  completedAt    DateTime?    @map("completed_at") @db.Timestamptz
  tenant         Tenant       @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, targetVersion])
  @@index([status, availableAt, leaseExpiresAt], map: "tenant_lifecycle_reconciliation_claim_idx")
  @@map("tenant_lifecycle_reconciliations")
  @@schema("core")
}

model PlatformAuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId      String   @map("actor_id") @db.VarChar(255)
  action       String   @db.VarChar(64)
  resourceType String   @map("resource_type") @db.VarChar(64)
  resourceId   String?  @map("resource_id") @db.Uuid
  tenantId     String?  @map("tenant_id") @db.Uuid
  metadata     Json     @default("{}") @db.JsonB
  ipAddress    String?  @map("ip_address") @db.Inet
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([tenantId, createdAt])
  @@index([createdAt])
  @@map("platform_audit_log")
  @@schema("core")
}
